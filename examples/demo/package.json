{
  "name": "designbook-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "designbook dev designbook.config.tsx --port 8788 --target-cmd \"vite --config vite.designbook.config.ts --port 3011 --strictPort\" --target-port 3011",
    "start": "designbook designbook.config.tsx",
    "build": "vite build",
    "check-types": "tsc --noEmit",
