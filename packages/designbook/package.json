{
  "name": "@designbookapp/designbook",
  "version": "0.5.0",
  "description": "Your React app from every angle — edit theme tokens, copy, and feature flags on the running app; an embedded Pi coding agent lands every edit as code.",
  "keywords": [
    "design-tool",
    "vite-plugin",
    "design-tokens",
    "i18n",
    "feature-flags",
    "figma",
    "coding-agent",
    "storybook-alternative",
    "react"
  ],
  "type": "module",
  "license": "MIT",
  "homepage": "https://designbook.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/designbookapp/designbook.git"
  },
  "bugs": {
    "url": "https://github.com/designbookapp/designbook/issues"
  },
  "bin": {
    "designbook": "./bin/designbook.js"
  },
  "exports": {
    ".": {
      "types": "./dist/node/plugin/plugin.d.ts",
      "default": "./dist/node/plugin/plugin.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "default": "./dist/config/index.js"
    },
    "./integration": {
      "types": "./dist/integration/index.d.ts",
      "default": "./dist/integration/index.js"
    },
    "./adapters": {
      "types": "./src/ui/adapters/index.ts",
      "default": "./dist/ui/adapters.js"
    },
    "./ui": {
      "types": "./src/ui/mount.tsx",
      "default": "./dist/ui/index.js"
    },
    "./ui/style.css": "./dist/ui/style.css",
    "./package.json": "./package.json"
  },
  "files": [
    "bin",
    "dist",
    "src/plugins",
    "src/ui",
    "src/config"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.node.json && node figma-plugin/build.mjs && pnpm build:ui && node scripts/copy-skills.mjs",
    "build:ui": "vite build --config vite.lib.config.ts",
    "dev": "tsc -p tsconfig.node.json --watch",
    "check-types": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.ui.json --noEmit",
    "check-types:figma-plugin": "tsc -p figma-plugin/tsconfig.json",
    "test:run": "vitest run",
    "test:figma": "node --experimental-strip-types test/figma-fidelity/run.ts",
    "lint:layers": "node scripts/layer-lint.mjs",
    "dogfood": "node dist/cli/index.js designbook.config.tsx --port 8842 --no-open",
    "build:figma-plugin": "node figma-plugin/build.mjs"
  },
  "peerDependencies": {
    "i18next": "^23 || ^24 || ^25 || ^26",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "react-i18next": "^13 || ^14 || ^15"
  },
  "peerDependenciesMeta": {
    "i18next": {
      "optional": true
    },
    "react-i18next": {
      "optional": true
    }
  },
  "dependencies": {
    "@babel/parser": "^7.29.7",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/merge": "^6.12.2",
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@fontsource-variable/geist": "^5.2.9",
    "@shadcn/react": "^0.2.0",
    "@tailwindcss/vite": "^4.1.11",
    "@uiw/react-codemirror": "^4.25.10",
    "@vitejs/plugin-react": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^25.2.1",
    "lucide-react": "^0.525.0",
    "magic-string": "^0.30.21",
    "radix-ui": "^1.6.1",
    "react-docgen-typescript": "^2.2.2",
    "react-i18next": "^15.5.3",
    "sass": "^1.101.0",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.3.4",
    "typebox": "1.1.38",
    "vite": "^7.0.0",
    "vite-tsconfig-paths": "^6.1.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.130.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.1",
    "pixelmatch": "^6.0.0",
    "playwright-core": "^1.49.0",
    "pngjs": "^7.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
