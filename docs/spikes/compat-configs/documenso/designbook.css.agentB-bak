/*
 * designbook <-> documenso Tailwind bridge.
 *
 * designbook bundles Tailwind v4 (@tailwindcss/vite); documenso ships a v3
 * config (packages/tailwind-config/index.cjs) that maps semantic tokens like
 * `bg-primary` -> `hsl(var(--primary))`. v4 ignores that JS config, so we
 * re-declare the tokens here via @theme and re-declare the runtime CSS vars
 * (copied from packages/ui/styles/theme.css, whose @tailwind v3 directives we
 * cannot import under v4).
 */
@import "tailwindcss";

/* documenso toggles dark via `.dark` on an ancestor (ignoring dark-mode-disabled). */
@custom-variant dark (&:is(.dark *));

@theme inline {
  --color-background: hsl(var(--background));
  --color-foreground: hsl(var(--foreground));
  --color-muted: hsl(var(--muted));
  --color-muted-foreground: hsl(var(--muted-foreground));
  --color-popover: hsl(var(--popover));
  --color-popover-foreground: hsl(var(--popover-foreground));
  --color-card: hsl(var(--card));
  --color-card-foreground: hsl(var(--card-foreground));
  --color-border: hsl(var(--border));
  --color-input: hsl(var(--input));
  --color-ring: hsl(var(--ring));
  --color-primary: hsl(var(--primary));
  --color-primary-foreground: hsl(var(--primary-foreground));
  --color-secondary: hsl(var(--secondary));
  --color-secondary-foreground: hsl(var(--secondary-foreground));
  --color-accent: hsl(var(--accent));
  --color-accent-foreground: hsl(var(--accent-foreground));
  --color-destructive: hsl(var(--destructive));
  --color-destructive-foreground: hsl(var(--destructive-foreground));
  --color-warning: hsl(var(--warning));
}

/* Runtime token values (light) — copied from packages/ui/styles/theme.css. */
:root {
  --background: 0 0% 100%;
  --foreground: 222.2 47.4% 11.2%;
  --muted: 210 40% 96.1%;
  --muted-foreground: 215.4 16.3% 46.9%;
  --popover: 0 0% 100%;
  --popover-foreground: 222.2 47.4% 11.2%;
  --card: 0 0% 100%;
  --card-foreground: 222.2 47.4% 11.2%;
  --border: 214.3 31.8% 91.4%;
  --input: 214.3 31.8% 91.4%;
  --primary: 95.08 71.08% 67.45%;
  --primary-foreground: 95.08 71.08% 10%;
  --secondary: 210 40% 96.1%;
  --secondary-foreground: 222.2 47.4% 11.2%;
  --accent: 210 40% 96.1%;
  --accent-foreground: 222.2 47.4% 11.2%;
  --destructive: 0 100% 50%;
  --destructive-foreground: 210 40% 98%;
  --ring: 95.08 71.08% 67.45%;
  --warning: 54 96% 45%;
  --radius: 0.5rem;
}

.dark {
  --background: 0 0% 14.9%;
  --foreground: 0 0% 97%;
  --muted: 0 0% 23.4%;
  --muted-foreground: 0 0% 85%;
  --popover: 0 0% 14.9%;
  --popover-foreground: 0 0% 90%;
  --card: 0 0% 14.9%;
  --card-foreground: 0 0% 95%;
  --border: 0 0% 27.9%;
  --input: 0 0% 27.9%;
  --primary: 95.08 71.08% 67.45%;
  --primary-foreground: 95.08 71.08% 10%;
  --secondary: 0 0% 23.4%;
  --secondary-foreground: 95.08 71.08% 67.45%;
  --accent: 0 0% 27.9%;
  --accent-foreground: 95.08 71.08% 67.45%;
  --destructive: 0 87% 62%;
  --destructive-foreground: 0 87% 19%;
  --ring: 95.08 71.08% 67.45%;
  --warning: 54 96% 45%;
}

body {
  background-color: hsl(var(--background));
  color: hsl(var(--foreground));
}
